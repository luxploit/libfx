libtomcrypt_lib = static_library('libtomcrypt',
	sources: libtomcrypt_sources,
	include_directories: [libtomcrypt_inc, libtommath_inc],
	c_args: [
		'/DLTC_NO_FAST',
		'/DLTC_NO_PROTOTYPES',
		'/DLTC_NO_RSA_BLINDING',
		'/DLTC_NO_FILE',
		'/DLTC_NO_TEST',
		'/DARGTYPE=4',
		'/D_CRT_SECURE_NO_WARNINGS',
		'/DLTC_SOURCE',
		'/D_LIB',
		'/DUSE_LTM',
		'/DLTM_DESC',
		'/U_DLL',
		'/U_USRDLL'
	],
	link_args: ['/IGNORE:4221'],
	override_options: ['warning_level=0'],
	name_prefix: ''
)

libtomcrypt_dep = declare_dependency(
	link_with: libtomcrypt_lib,
	include_directories: libtomcrypt_inc
)

# =============================================================================
# lz4 (static, C)
# =============================================================================
lz4_inc = [
	include_directories('lz4/lib'),
]

lz4_sources = files(
	'lz4/lib/lz4.c',
)

lz4_lib = static_library('lz4',
	sources: lz4_sources,
	include_directories: lz4_inc,
	override_options: ['warning_level=0'],
	name_prefix: ''
)

lz4_dep = declare_dependency(
	link_with: lz4_lib,
	include_directories: lz4_inc
)

# =============================================================================
# ZeroBlue (header-only, C++)
# =============================================================================
zeroblue_dep = declare_dependency(
	include_directories: include_directories('ZeroBlue/src')
)