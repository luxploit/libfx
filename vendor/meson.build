	'libtommath/s_mp_zero_digs.c'
)

libtommath_lib = static_library('libtommath',
	sources: libtommath_sources,
	include_directories: libtommath_inc,
	c_args: [
		'/DLTM_DESC',
		'/D__STDC_IEC_559__',
		'/DMP_NO_DEV_URANDOM',
		'/D_LIB',
		'/U_DLL',
		'/U_USRDLL',
		'/clang:-Wno-format'
	],
	link_args: ['/IGNORE:4221'],
	override_options: ['warning_level=0'],
	name_prefix: ''
)

libtommath_dep = declare_dependency(
  link_with: libtommath_lib,
  include_directories: libtommath_inc
)

